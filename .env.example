# Bu dosyanın bir kopyasını ".env" adıyla oluştur ve anahtarını yaz.
# .env dosyası git'e gitmez (.gitignore'da).
# UYARI: Bu projeyi web'e deploy edersen .env tarayıcıdan okunabilir olur.
# .env yaklaşımı SADECE yerel geliştirme içindir.

VITE_GEMINI_API_KEY=YOUR_API_KEY_HERE

# Bitiş müziği için (isteğe bağlı) — yoksa prosedürel Web Audio sentezi çalar.
# Replicate MusicGen, ücretli (~$0.06/üretim): https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=YOUR_REPLICATE_TOKEN_HERE
